# ==========================================================
# Uhasibu Digito — env template
# Copy this file to .env and replace placeholders with real values.
# Safe to commit — no real credentials.
# ==========================================================

# -------- Database — TiDB Cloud (MySQL-compatible) ---------
DATABASE_URL="mysql://<USER>:<PASSWORD>@gateway01.<REGION>.prod.aws.tidbcloud.com:4000/uhasibu_digito?sslaccept=strict"
DIRECT_DATABASE_URL="mysql://<USER>:<PASSWORD>@gateway01.<REGION>.prod.aws.tidbcloud.com:4000/uhasibu_digito?sslaccept=strict"

# -------- Auth.js v5 (NextAuth) ----------------------------
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_HEX_32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# -------- Email — Resend -----------------------------------
RESEND_API_KEY="re_REPLACE_ME"
EMAIL_FROM="Uhasibu Digito <no-reply@mail.uhasibudigito.co.tz>"

# -------- File storage — Cloudflare R2 (S3-compatible) -----
S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
S3_BUCKET="uhasibu-digito-files"
S3_REGION="auto"
S3_ACCESS_KEY_ID="REPLACE_ME"
S3_SECRET_ACCESS_KEY="REPLACE_ME"
S3_PUBLIC_URL="https://files.uhasibudigito.co.tz"

# -------- Scheduled jobs (cron) ----------------------------
# Bearer secret the tax-reminder cron checks. Vercel Cron sends it automatically when set;
# any external scheduler must send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="REPLACE_WITH_OPENSSL_RAND_HEX_32"

# -------- Observability — Sentry ---------------------------
SENTRY_DSN="REPLACE_ME"
SENTRY_AUTH_TOKEN="REPLACE_ME"
SENTRY_ORG="uhasibu-digito"
SENTRY_PROJECT="web"

# -------- Feature flags ------------------------------------
NEXT_PUBLIC_BACKEND_ENABLED_MODULES=""

# -------- App ----------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
