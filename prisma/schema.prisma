// Uhasibu Digito — Prisma schema (Wave 0)
// Single source of truth for the backend data model.
//
// Conventions:
// * Every tenant-scoped model carries: id (cuid), tenant_id, created_at,
//   updated_at, created_by_id, plus @@index([tenantId]) and
//   @@index([tenantId, createdAt]). tenant_id is a plain indexed scalar —
//   the Prisma client extension in lib/server/db.ts is the policy engine
//   (see lib/server/tenant-scope.ts for the TENANT_SCOPED_MODELS allowlist).
// * Money is always Decimal(20,2). Never Float. Never Int-in-cents.
// * Dates are DateTime (UTC); displayed in Africa/Dar_es_Salaam at render time.
// * Domain string-unions (status/type/role) are stored as String columns and
//   validated by zod at the write boundary, not as Prisma enums — this keeps
//   Prisma return types directly assignable to the existing TS unions in
//   types/index.ts and avoids enum-value @map ceremony for values with spaces
//   (e.g. "Finance Manager").
// * relationMode = "prisma": referential integrity is enforced by the Prisma
//   client, NOT by DB-level foreign keys. This is the TiDB-friendly choice —
//   TiDB does not enforce FKs by default, and hot-write tables (gl_entries,
//   bank_transactions, stock_movements) must avoid FK-check overhead.
//   AUTO_RANDOM PKs for those hot tables are deferred to the first real
//   `migrate dev` in Wave 1 (no DB exists yet to validate raw-SQL augmentation).
//
// Auth.js tables (User, Account, Session, VerificationToken, Tenant, Membership)
// are NOT tenant-scoped at write time — the Auth.js PrismaAdapter uses a raw,
// unscoped client. They are intentionally absent from TENANT_SCOPED_MODELS.

generator client {
  provider = "prisma-client-js"
}

// Connection URLs live in prisma.config.ts (Prisma 7); the PrismaClient
// constructor receives a driver adapter (see lib/server/db.ts).
datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

// ===================================================================
// Identity & tenancy (NOT tenant-scoped by the extension)
// ===================================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  tier      String   @default("free")
  status    String   @default("active") // active | pending_approval — gates access while a bank-transfer invoice awaits admin approval
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  memberships Membership[]

  @@map("tenants")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  // Domain extensions
  role         String    @default("Accountant") // UserRole union
  initials     String?
  phone        String?
  passwordHash String?   @map("password_hash")
  tenantId     String?   @map("tenant_id")
  departmentId String?   @map("department_id")
  branchId     String?   @map("branch_id") // staff sub-accounts bound to a branch (Branch Manager / Cashier)
  disabledAt   DateTime? @map("disabled_at") // deactivated staff can't sign in; kept for history
  isSuperAdmin Boolean   @default(false) @map("is_super_admin") // platform super-admin (cross-tenant operator)

  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id])
  branch                  Branch?              @relation(fields: [branchId], references: [id])
  accounts                Account[]
  sessions                Session[]
  memberships             Membership[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([branchId])
  @@index([isSuperAdmin])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Password reset — short-lived single-use tokens (only the SHA-256 hash is stored).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Email verification — short-lived single-use tokens (only the SHA-256 hash is stored).
// Mirrors PasswordResetToken. A new credential account cannot sign in until its token is consumed
// (User.emailVerified set).
model EmailVerificationToken {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  tokenHash     String    @unique @map("token_hash")
  expiresAt     DateTime  @map("expires_at")
  usedAt        DateTime? @map("used_at")
  // The 6-digit code (sha256 hash) generated on-demand when the user opens the code page.
  codeHash      String?   @map("code_hash")
  codeExpiresAt DateTime? @map("code_expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Company identity (1:1 with tenant) — replaces the old COMPANY mock constant. Drives
// invoice/statement/report headers and the Settings → Company page.
model CompanyProfile {
  id                String   @id @default(cuid())
  tenantId          String   @unique @map("tenant_id")
  name              String
  shortName         String   @default("") @map("short_name")
  tin               String   @default("")
  vatNumber         String   @default("") @map("vat_number")
  efdSerial         String   @default("") @map("efd_serial")
  nbaaNumber        String   @default("") @map("nbaa_number")
  regNumber         String   @default("") @map("reg_number")
  address           String   @default("")
  branch            String   @default("")
  region            String   @default("")
  country           String   @default("")
  countryCode       String   @default("") @map("country_code")
  district          String   @default("")
  street            String   @default("")
  latitude          Float?
  longitude         Float?
  heardFrom         String   @default("") @map("heard_from")
  businessType      String   @default("") @map("business_type")
  email             String   @default("")
  phone             String   @default("")
  phoneCountryCode  String   @default("") @map("phone_country_code")
  website           String   @default("")
  financialYearStart String  @default("January") @map("financial_year_start")
  financialYearEnd   String  @default("December") @map("financial_year_end")
  fiscalYearStartMonth Int    @default(1) @map("fiscal_year_start_month") // 1=Jan … 12=Dec
  booksLockedThrough DateTime? @map("books_locked_through") // journals dated on/before this are rejected
  baseCurrency      String   @default("TZS") @map("base_currency")
  secondaryCurrency String   @default("USD") @map("secondary_currency")
  logoUrl           String?  @map("logo_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("company_profiles")
}

// Generic uploaded document (Vercel Blob). Polymorphic owner (ownerType + ownerId) so it
// attaches to invoices, purchase orders, audit step results, etc.
model Document {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  ownerType    String   @map("owner_type")
  ownerId      String   @map("owner_id")
  url          String   @db.Text
  pathname     String
  fileName     String   @map("file_name")
  mimeType     String   @map("mime_type")
  size         Int
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, ownerType, ownerId])
  @@map("documents")
}

// Forward-compat: user × tenant × role join for future multi-tenant users
model Membership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  role      String
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

// ===================================================================
// Organisation (tenant-scoped)
// ===================================================================

model Department {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  users User[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("departments")
}

// ===================================================================
// Finance core
// ===================================================================

model COAAccount {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  code           String
  name           String
  type           String // AccountType union
  parentCode     String?  @map("parent_code")
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(20, 2)
  movement       Decimal  @default(0) @db.Decimal(20, 2)
  closingBalance Decimal  @default(0) @map("closing_balance") @db.Decimal(20, 2)
  level          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    String?  @map("created_by_id")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("coa_accounts")
}

model JournalEntryGroup {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  reference     String
  narration     String    @db.Text
  status        String    @default("Posted") // Posted | Reversed
  reversesRef   String    @default("") @map("reverses_ref")   // set on a contra entry → the reference it reverses
  reversedByRef String    @default("") @map("reversed_by_ref") // set on the original once a contra reverses it
  postedById    String?   @map("posted_by_id")
  postedAt      DateTime  @default(now()) @map("posted_at")
  editedAt      DateTime? @map("edited_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdById   String?   @map("created_by_id")

  entries GLEntry[]

  // Reference is no longer DB-unique (append-only: original + contra + revisions may share a base
  // reference). Active-reference uniqueness is enforced in postJournalEntry at the app layer.
  @@index([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("journal_entry_groups")
}

// Hot-write table — no DB FK on tenant/group (relationMode = prisma).
model GLEntry {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  groupId     String?  @map("group_id")
  date        DateTime
  reference   String
  narration   String   @db.Text
  account     String
  accountCode String   @map("account_code")
  costCentre  String   @default("HQ") @map("cost_centre")
  debit       Decimal  @default(0) @db.Decimal(20, 2)
  credit      Decimal  @default(0) @db.Decimal(20, 2)
  balance     Decimal  @default(0) @db.Decimal(20, 2)
  postedBy    String   @map("posted_by")
  postedAt    DateTime @default(now()) @map("posted_at")
  status      String   @default("Posted") // GLStatus
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  group JournalEntryGroup? @relation(fields: [groupId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, date])
  @@index([tenantId, accountCode, date])
  @@index([tenantId, reference])
  @@index([groupId])
  @@map("gl_entries")
}

model BankAccount {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  bankName       String   @map("bank_name")
  accountName    String   @map("account_name")
  accountNumber  String   @map("account_number")
  currency       String   @default("TZS") // BankCurrency
  balance        Decimal  @default(0) @db.Decimal(20, 2)
  balanceUSD     Decimal? @map("balance_usd") @db.Decimal(20, 2)
  coaAccountCode String?  @map("coa_account_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    String?  @map("created_by_id")

  transactions BankTransaction[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("bank_accounts")
}

// Hot-write table.
model BankTransaction {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  bankAccountId String   @map("bank_account_id")
  date          DateTime
  description   String   @db.Text
  debit         Decimal  @default(0) @db.Decimal(20, 2)
  credit        Decimal  @default(0) @db.Decimal(20, 2)
  balance       Decimal  @default(0) @db.Decimal(20, 2)
  reference     String
  matched       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, bankAccountId, date])
  @@index([bankAccountId])
  @@map("bank_transactions")
}

// A line imported from a bank statement, matched against the GL-mirrored BankTransaction rows
// during reconciliation. amount is signed (+ credit/inflow, − debit/outflow).
model BankStatementLine {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  bankAccountId String   @map("bank_account_id")
  date          DateTime
  description   String   @db.Text
  amount        Decimal  @default(0) @db.Decimal(20, 2)
  reference     String   @default("")
  matched       Boolean  @default(false)
  matchedTxnId  String?  @map("matched_txn_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")

  @@index([tenantId])
  @@index([tenantId, bankAccountId, date])
  @@map("bank_statement_lines")
}

// ===================================================================
// Sales
// ===================================================================

model Customer {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  name               String
  contactPerson      String   @map("contact_person")
  tin                String
  phone              String
  email              String
  city               String
  address            String   @db.Text
  creditLimit        Decimal  @default(0) @map("credit_limit") @db.Decimal(20, 2)
  outstandingBalance Decimal  @default(0) @map("outstanding_balance") @db.Decimal(20, 2)
  status             String   @default("Active") // CustomerStatus
  paymentTerms       String   @map("payment_terms")
  totalRevenue       Decimal  @default(0) @map("total_revenue") @db.Decimal(20, 2)
  country            String?
  swiftBic           String?  @map("swift_bic")
  beneficiaryBank    String?  @map("beneficiary_bank")
  iban               String?
  isInternational    Boolean? @map("is_international")
  // CRM extension fields (CRMCustomer)
  leadSource         String?  @map("lead_source")
  assignedTo         String?  @map("assigned_to")
  lastContact        String?  @map("last_contact")
  notes              String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdById        String?  @map("created_by_id")

  invoices   Invoice[]
  quotations Quotation[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("customers")
}

model Invoice {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  number       String
  customerId   String    @map("customer_id")
  customerName String    @map("customer_name")
  issueDate    DateTime  @map("issue_date")
  dueDate      DateTime  @map("due_date")
  subtotal     Decimal   @default(0) @db.Decimal(20, 2)
  discount     Decimal   @default(0) @db.Decimal(20, 2)
  vatAmount    Decimal   @default(0) @map("vat_amount") @db.Decimal(20, 2)
  total        Decimal   @default(0) @db.Decimal(20, 2)
  amountPaid   Decimal   @default(0) @map("amount_paid") @db.Decimal(20, 2)
  status       String    @default("Draft") // InvoiceStatus
  efdNumber    String    @map("efd_number")
  journalRef   String    @default("") @map("journal_ref")
  quotationId  String?   @map("quotation_id") // set when created by converting a quotation
  publicToken  String?   @unique @map("public_token") // unguessable token for the public invoice link
  notes        String    @db.Text
  paidAt       DateTime? @map("paid_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdById  String?   @map("created_by_id")

  customer Customer         @relation(fields: [customerId], references: [id])
  lines    InvoiceLine[]
  sendLog  SendLogEntry[]
  payments InvoicePayment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, customerId, issueDate])
  @@index([customerId])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  invoiceId   String   @map("invoice_id")
  description String   @db.Text
  quantity    Decimal  @default(0) @db.Decimal(20, 2)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(20, 2)
  discountPct Decimal  @default(0) @map("discount_pct") @db.Decimal(20, 2)
  vatPct      Decimal  @default(0) @map("vat_pct") @db.Decimal(20, 2)
  lineTotal   Decimal  @default(0) @map("line_total") @db.Decimal(20, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_lines")
}

model Quotation {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  number             String
  customerId         String   @map("customer_id")
  customerName       String   @map("customer_name")
  date               DateTime
  validUntil         DateTime @map("valid_until")
  subtotal           Decimal  @default(0) @db.Decimal(20, 2)
  vatAmount          Decimal  @default(0) @map("vat_amount") @db.Decimal(20, 2)
  total              Decimal  @default(0) @db.Decimal(20, 2)
  status             String   @default("Draft") // QuotationStatus
  notes              String?  @db.Text
  convertedInvoiceId String?  @map("converted_invoice_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdById        String?  @map("created_by_id")

  customer Customer        @relation(fields: [customerId], references: [id])
  lines    QuotationLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([customerId])
  @@map("quotations")
}

model QuotationLine {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  quotationId String   @map("quotation_id")
  description String   @db.Text
  quantity    Decimal  @default(0) @db.Decimal(20, 2)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(20, 2)
  discountPct Decimal  @default(0) @map("discount_pct") @db.Decimal(20, 2)
  vatPct      Decimal  @default(0) @map("vat_pct") @db.Decimal(20, 2)
  lineTotal   Decimal  @default(0) @map("line_total") @db.Decimal(20, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quotationId])
  @@map("quotation_lines")
}

model RecurringInvoice {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  customerId    String    @map("customer_id")
  customerName  String    @map("customer_name")
  frequency     String // Weekly | Monthly | Quarterly | Yearly
  interval      Int       @default(1) // every N periods
  nextRunAt     DateTime  @map("next_run_at")
  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  active        Boolean   @default(true)
  notes         String    @db.Text
  lastInvoiceId String?   @map("last_invoice_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdById   String?   @map("created_by_id")

  lines RecurringInvoiceLine[]

  @@index([tenantId])
  @@index([tenantId, active, nextRunAt])
  @@map("recurring_invoices")
}

model RecurringInvoiceLine {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  recurringId String   @map("recurring_id")
  description String   @db.Text
  quantity    Decimal  @default(0) @db.Decimal(20, 2)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(20, 2)
  discountPct Decimal  @default(0) @map("discount_pct") @db.Decimal(20, 2)
  vatPct      Decimal  @default(18) @map("vat_pct") @db.Decimal(20, 2)
  lineTotal   Decimal  @default(0) @map("line_total") @db.Decimal(20, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  recurring RecurringInvoice @relation(fields: [recurringId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recurringId])
  @@map("recurring_invoice_lines")
}

// User-targeted in-app notification (bell/inbox). Deliberately NOT tenant-scoped: it also serves
// tenant-less platform super-admins, and is always queried by the recipient's userId.
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String?  @map("tenant_id")
  type      String   @default("info") // info | success | warning | error | payment
  title     String
  body      String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model SendLogEntry {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  invoiceId     String   @map("invoice_id")
  invoiceNumber String   @map("invoice_number")
  customerName  String   @map("customer_name")
  channel       String // SendChannel
  recipient     String
  sentAt        DateTime @default(now()) @map("sent_at")
  status        String   @default("Queued") // SendStatus
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([invoiceId])
  @@map("send_log_entries")
}

// A payment received against a customer invoice (accounts receivable). Posts to the GL
// (Dr Cash/Bank, Cr Trade Receivables) via journalRef, which enables reversal.
model InvoicePayment {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  invoiceId     String   @map("invoice_id")
  invoiceNumber String   @map("invoice_number")
  customerId    String   @map("customer_id")
  customerName  String   @map("customer_name")
  amount        Decimal  @default(0) @db.Decimal(20, 2)
  method        String // PaymentMethod: cash | mpesa | bank | cheque | card
  reference     String   @default("")
  paidAt        DateTime @map("paid_at")
  journalRef    String   @default("") @map("journal_ref")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, paidAt])
  @@index([invoiceId])
  @@map("invoice_payments")
}

// A business expense/payment. Posts to the GL (Dr expense account, Cr cash/bank or Trade
// Payables) via journalRef, which enables reversal on delete.
model Expense {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  date          DateTime
  category      String // COA expense account code (e.g. 6200)
  categoryName  String   @map("category_name")
  payee         String   @default("")
  description   String   @db.Text
  amount        Decimal  @default(0) @db.Decimal(20, 2)
  vatAmount     Decimal  @default(0) @map("vat_amount") @db.Decimal(20, 2)
  paymentMethod String   @map("payment_method") // cash | mpesa | bank | credit
  reference     String   @default("")
  journalRef    String   @default("") @map("journal_ref")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("expenses")
}

