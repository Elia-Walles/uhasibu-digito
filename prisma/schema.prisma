  sdl          Decimal  @default(0) @db.Decimal(20, 2)
  heslb        Decimal  @default(0) @db.Decimal(20, 2)
  netPay       Decimal  @default(0) @map("net_pay") @db.Decimal(20, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  String?  @map("created_by_id")

