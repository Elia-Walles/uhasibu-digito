// Hot-write table.
model StockMovement {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  itemId       String   @map("item_id")
  branchId     String?  @map("branch_id")
  date         DateTime
  reference    String
  itemName     String   @map("item_name")
  itemCode     String   @map("item_code")
  type         String // MovementType
  quantity     Decimal  @default(0) @db.Decimal(20, 2)
  unitCost     Decimal  @default(0) @map("unit_cost") @db.Decimal(20, 2)
  totalValue   Decimal  @default(0) @map("total_value") @db.Decimal(20, 2)
  balanceAfter Decimal  @default(0) @map("balance_after") @db.Decimal(20, 2)
  narration    String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  String?  @map("created_by_id")

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, itemId, date])
  @@index([tenantId, branchId, date])
  @@index([itemId])
  @@map("stock_movements")
}

// Per-branch on-hand quantity for an item. InventoryItem.onHand stays the global total
// (sum across branches); this table holds the branch-level breakdown. Tenant-scoped by the
// client extension. Plain scalar branchId/itemId (no FK relation) — same convention as the
// hot POS/movement tables under relationMode = "prisma".
model BranchStock {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  itemId    String   @map("item_id")
  onHand    Decimal  @default(0) @map("on_hand") @db.Decimal(20, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, branchId, itemId])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([itemId])
  @@map("branch_stock")
}

