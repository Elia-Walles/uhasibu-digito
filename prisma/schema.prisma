  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("budget_lines")
}

// ===================================================================
// Audit (engagement workpapers)
// ===================================================================

model AuditEngagement {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  period      String
  auditorName String   @map("auditor_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  steps AuditStepResult[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("audit_engagements")
}

model AuditStepResult {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  engagementId String?  @map("engagement_id")
  procedure    String // AuditProcedure
  stepKey      String   @map("step_key")
  status       String   @default("Pending") // AuditStepStatus
  notes        String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdById  String?  @map("created_by_id")

  engagement AuditEngagement? @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([tenantId, procedure, stepKey])
  @@index([tenantId])
  @@index([engagementId])
  @@map("audit_step_results")
}

// ===================================================================
// Audit log (immutable activity trail)
// ===================================================================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  timestamp   DateTime @default(now())
  userId      String?  @map("user_id")
  userName    String   @map("user_name")
  action      String // AuditAction
  module      String
  recordRef   String   @map("record_ref")
  ipAddress   String   @map("ip_address")
  details     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ===================================================================
// Platform billing & governance (NOT tenant-scoped — managed by the
// super-admin via lib/server/admin-db.ts; intentionally absent from
// TENANT_SCOPED_MODELS in lib/server/tenant-scope.ts)
// ===================================================================

model Plan {
  id        String   @id @default(cuid())
  key       String   @unique // Tier key: "starter" | "business" | "enterprise" — drives gating (lib/auth/tiers.ts)
  name      String
  tagline   String   @default("")
  priceTzs  Decimal  @default(0) @map("price_tzs") @db.Decimal(20, 2)
  interval  String   @default("year") // "year" | "month"
  features  String   @db.Text // JSON-encoded string[]
  isActive  Boolean  @default(true) @map("is_active")
  highlighted Boolean @default(false) // "Most popular" badge on pricing surfaces
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id") // plain scalar — NOT extension-scoped
  planId           String    @map("plan_id")
  status           String    @default("active") // active | past_due | canceled | trialing
  startedAt        DateTime  @default(now()) @map("started_at")
  currentPeriodEnd DateTime? @map("current_period_end")
  canceledAt       DateTime? @map("canceled_at")
  amountTzs        Decimal   @default(0) @map("amount_tzs") @db.Decimal(20, 2)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([tenantId])
  @@index([status])
  @@index([planId])
  @@map("subscriptions")
}

model Payment {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  subscriptionId String?  @map("subscription_id")
  amountTzs      Decimal  @default(0) @map("amount_tzs") @db.Decimal(20, 2)
  method         String   @default("manual") // manual | mpesa | bank | cash
  reference      String   @default("") // operator-entered receipt / txn ref
  status         String   @default("recorded") // recorded | reversed
  paidAt         DateTime @map("paid_at")
  note           String   @db.Text
  recordedById   String?  @map("recorded_by_id") // super-admin User.id
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([paidAt])
  @@map("payments")
}

// Subscription invoice — the bank-transfer proforma a tenant receives when it picks a plan during
// onboarding (or a plan change). NOT tenant-scoped (platform-level, managed via authDb/adminDb).
// The admin approves it, which creates the Subscription + Payment and activates the tenant.
model SubscriptionInvoice {
  id              String    @id @default(cuid())
  number          String    @unique // SUB-YYYY-#####
  tenantId        String    @map("tenant_id")
  userId          String    @map("user_id") // the owner who generated it
  planKey         String    @map("plan_key") // starter | business | standard | premium
  planName        String    @map("plan_name")
  billingInterval String    @default("year") @map("billing_interval")
  amountTzs       Decimal   @default(0) @map("amount_tzs") @db.Decimal(20, 2) // total (no VAT)
  currency        String    @default("TZS")
  status          String    @default("unpaid") // unpaid | paid | cancelled
  issuedAt        DateTime  @default(now()) @map("issued_at")
  dueAt           DateTime  @map("due_at") // issuedAt + 24h
  submittedAt     DateTime? @map("submitted_at") // when the user clicked Done
  paidAt          DateTime? @map("paid_at") // when the admin approved
  approvedById    String?   @map("approved_by_id") // super-admin User.id
  billToCompany   String    @map("bill_to_company")
  billToEmail     String    @map("bill_to_email")
  billToName      String    @default("") @map("bill_to_name")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("subscription_invoices")
}

// Global, cross-tenant operator audit trail — distinct from the tenant-scoped AuditLog.
model PlatformAuditLog {
  id             String   @id @default(cuid())
  actorUserId    String   @map("actor_user_id") // super-admin who acted
  actorEmail     String   @map("actor_email")
  action         String // e.g. "tenant.tier.change", "payment.record"
  targetType     String   @map("target_type") // "Tenant" | "User" | "Subscription" | "Payment" | "Plan"
  targetId       String   @map("target_id")
  targetTenantId String?  @map("target_tenant_id")
  details        String   @db.Text // JSON-encoded before/after
  ipAddress      String   @default("") @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([targetTenantId])
  @@index([createdAt])
  @@map("platform_audit_logs")
}
