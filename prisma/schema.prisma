model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  code          String
  name          String
  category      String
  unit          String
  onHand        Decimal  @default(0) @map("on_hand") @db.Decimal(20, 2)
